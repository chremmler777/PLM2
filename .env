# PLM System - Development Environment Configuration

# Application
APP_NAME="PLM System v2"
APP_VERSION="0.2.0"
DEBUG=true

# Database
DATABASE_URL=postgresql+asyncpg://plm:plm@localhost:5432/plm

# Redis
REDIS_URL=redis://:plm@localhost:6379/0

# File Storage
UPLOAD_DIR=/app/storage/uploads
GLTF_DIR=/app/storage/gltf
MAX_UPLOAD_SIZE=104857600

# Security
SECRET_KEY=dev-secret-key-please-change-in-production-12345678901234567890
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# Admin Setup
ADMIN_REGISTRATION_CODE=ADMIN-DEV-CODE

# SMTP (disabled in dev)
SMTP_ENABLED=false
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=noreply@example.com

# Frontend
FRONTEND_URL=http://localhost:5173

# Password Reset
PASSWORD_RESET_EXPIRE_HOURS=24

# Account Lockout
MAX_LOGIN_ATTEMPTS=5
LOCKOUT_DURATION_MINUTES=30

# Notifications
NOTIFICATION_TASK_ASSIGNED=true
NOTIFICATION_TASK_COMPLETED=true
NOTIFICATION_ESCALATION=true
NOTIFICATION_WORKFLOW_COMPLETE=true
